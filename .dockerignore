# ─── Dependencies (rebuilt inside container) ─────────────────────────────────
node_modules
*/node_modules

# ─── Environment files (secrets never baked into image) ──────────────────────
.env
.env.*
!.env.example

# ─── Build artifacts ─────────────────────────────────────────────────────────
host/dist
dist

# ─── Git & CI ────────────────────────────────────────────────────────────────
.git
.github
.gitignore

# ─── Documentation (not needed at runtime) ───────────────────────────────────
*.md
!README.md
PRD.md
TESTING.md

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs

# ─── OS metadata ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editor files ────────────────────────────────────────────────────────────
.vscode
.idea
*.sw?

# ─── Host agent (not needed for relay image but required for Railpack npm ci) ──
# host/bin
# host/src
# host/crypto.js
# host/webrtc.js
# host/index.js
host/.env
host/.env.example
# host/package-lock.json
